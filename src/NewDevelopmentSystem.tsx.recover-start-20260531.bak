const lightInputCls = 'w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm text-slate-900 outline-none focus:ring-2 focus:ring-sky-500';
const emptyDraft = { title: '', alias: '', barcode: '', standard: '', brandId: '', spec: '' };

const dataLabels: Record<string, string> = {
  initiationSellingPoints: '绔嬮」鍗栫偣',
  sellingPoints: '鍗栫偣淇℃伅',
  testItems: '闇€瑕佹娴嬮」鐩?,
  feasibleTestItems: '鍙仛妫€娴嬮」鐩?,
  purchaseReview: '閲囪喘瀹℃牳璇存槑',
  copywritingConfirm: '鏂囨鍜屾娴嬮」鐩‘璁?,
  packagingSourceFiles: '鍖呰婧愭枃浠?,
  packagingPreviewImages: '鍖呰棰勮鍥?,
  whiteBackgroundImages: '鐧藉簳鍥?,
  assignedDesigner: '鎸囧畾璁捐',
  designSelfCheck: '鑷垜瀹℃牳鎻愮ず璇?,
  mainDetailSourceFiles: '涓诲浘璇︽儏婧愭枃浠?,
