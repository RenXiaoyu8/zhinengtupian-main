import {
  ArrowLeft,
  Bell,
  Check,
  ChevronDown,
  ChevronRight,
  Clock,
  FileText,
  History,
  Image as ImageIcon,
  PackageOpen,
  Plus,
  RotateCcw,
  Save,
  Settings,
  Trash2,
  Upload,
  X,
} from 'lucide-react';
