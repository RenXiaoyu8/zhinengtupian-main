const API_BASE = '/api';

type ManagedUser = { username: string; role: string };
type BrandOption = { id: number; name: string };
type OpsRotation = { usernames: string[]; currentIndex: number; currentUsername: string; weekKey: string };
type StepConfig = {
  stepKey: string;
  stepOrder: number;
  label: string;
  durationHours: number;
  assigneeUsernames: string[];
  assigneePositions: string[];
  escalationHours: number;
  escalationUsernames: string[];
  escalationPositions: string[];
};
type NewDevProject = {
  id: number;
  title: string;
  barcode: string;
  standard: string;
  brand: string;
  spec: string;
  currentStepKey: string;
  dueAt: string | null;
  data: Record<string, any>;
  createdBy: string;
  createdAt: string;
  updatedAt: string;
  completedAt: string | null;
  assignees: string[];
};
type HistoryChange = { field: string; label: string; from: any; to: any };
type FlowHistoryEntry = {
  id: string;
  at: string;
  user: string;
  stepKey: string;
  stepLabel: string;
  action: string;
  summary: string;
  changes?: HistoryChange[];
  snapshot?: Record<string, any>;
};

function uniqueStrings(...lists: any[][]): string[] {
  const result: string[] = [];
  const seen = new Set<string>();
  for (const list of lists) {
    for (const item of Array.isArray(list) ? list : []) {
      const text = String(item || '').trim();
      if (!text) continue;
      const key = text.toLowerCase();
      if (seen.has(key)) continue;
      seen.add(key);
      result.push(text);
    }
  }
  return result;
}

function mergeFileMaps(latest: any, current: any, keys: string[]) {
  const result: Record<string, any[]> = {};
  const latestObj = latest && typeof latest === 'object' && !Array.isArray(latest) ? latest : {};
  const currentObj = current && typeof current === 'object' && !Array.isArray(current) ? current : {};
  for (const key of keys) {
    const currentFiles = asArray(currentObj[key]);
    const latestFiles = asArray(latestObj[key]);
    result[key] = currentFiles.length ? currentFiles.slice(0, 3) : latestFiles.slice(0, 3);
  }
  return result;
}

function uniqueFiles(...lists: any[][]) {
  const result: any[] = [];
  const seen = new Set<string>();
  for (const list of lists) {
    for (const file of Array.isArray(list) ? list : []) {
      const key = String(file?.path || file?.name || '').trim();
      if (!key || seen.has(key)) continue;
      seen.add(key);
      result.push(file);
    }
  }
  return result;
}

function mergeSellingDraftData(latestData: any, currentData: any) {
  const mergeEditableRows = (latestList: any, currentList: any) => {
    const currentRows = Array.isArray(currentList) ? currentList.map(item => String(item || '')) : [];
    const latestRows = Array.isArray(latestList) ? latestList.map(item => String(item || '')) : [];
    const sourceRows = currentRows.length ? currentRows : latestRows;
    return sourceRows.length ? sourceRows : [''];
  };
  const sellingPoints = mergeEditableRows(latestData?.sellingPoints, currentData?.sellingPoints);
  const testItems = mergeEditableRows(latestData?.testItems, currentData?.testItems);
  const referenceLinks = uniqueStrings(latestData?.referenceLinks, currentData?.referenceLinks);
  return {
    ...(latestData || {}),
    ...(currentData || {}),
    sellingPoints,
    testItems,
    referenceLinks,
    sellingPointImages: mergeFileMaps(latestData?.sellingPointImages, currentData?.sellingPointImages, sellingPoints),
    testItemImages: mergeFileMaps(latestData?.testItemImages, currentData?.testItemImages, testItems),
    sellingPointAuthors: { ...(latestData?.sellingPointAuthors || {}), ...(currentData?.sellingPointAuthors || {}) },
    sellingPointEditors: { ...(latestData?.sellingPointEditors || {}), ...(currentData?.sellingPointEditors || {}) },
    testItemAuthors: { ...(latestData?.testItemAuthors || {}), ...(currentData?.testItemAuthors || {}) },
    testItemEditors: { ...(latestData?.testItemEditors || {}), ...(currentData?.testItemEditors || {}) },
  };
}

function sellingSyncKey(data: any) {
  return JSON.stringify({
    sellingPoints: data?.sellingPoints || [],
    sellingPointImages: data?.sellingPointImages || {},
    testItems: data?.testItems || [],
    testItemImages: data?.testItemImages || {},
    referenceLinks: data?.referenceLinks || [],
    editLocks: data?.editLocks || {},
  });
}

function compactHistoryValue(value: any): any {
  if (typeof value === 'string') {
    if (/^data:/i.test(value) || value.length > 200000) return '[large value omitted]';
    return value;
  }
  if (Array.isArray(value)) return value.slice(0, 20).map(compactHistoryValue);
  if (value && typeof value === 'object') {
    const result: Record<string, any> = {};
    Object.entries(value).forEach(([key, item]) => {
      if (key === 'snapshot' || key === 'history') return;
      result[key] = compactHistoryValue(item);
    });
    return result;
  }
  return value;
}

function compactNewDevDataForSave(data: any) {
  const nextData = data && typeof data === 'object' && !Array.isArray(data) ? { ...data } : {};
  if (Array.isArray(nextData.history)) {
    nextData.history = nextData.history.slice(-80).map((entry: any) => {
      const compact = entry && typeof entry === 'object' ? { ...entry } : {};
      delete compact.snapshot;
      if (Array.isArray(compact.changes)) {
        compact.changes = compact.changes.slice(-30).map((change: any) => ({
          ...change,
          from: compactHistoryValue(change?.from),
          to: compactHistoryValue(change?.to),
        }));
      }
      return compact;
    });
  }
  return nextData;
}

function compactNewDevProjectForSave(project: NewDevProject): NewDevProject {
  return { ...project, data: compactNewDevDataForSave(project.data || {}) };
}

